  optional double weekClose = 50; // Önceki Hafta Kapanış
  optional double monthClose = 51; // Önceki Ay Kapanış
  optional double yearClose = 52; // Önceki Yıl Kapanış
  optional double preSettlement = 53; // Önceki Uzlaşma
